def pair_sum(arr, target):
    for i in range(len(arr)):
        for j in range(i + 1, len(arr)):
            if arr[i] + arr[j] == target:
                return (i, j)
    return None
arr = [2, 7, 11, 15]
target = 9
result = pair_sum(arr, target)
if result:
    print("Pair found at indices:", result)
else:
    print("No pair found")
